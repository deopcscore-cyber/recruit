{
  "manifest_version": 3,
  "name": "Recruit Pro Importer",
  "version": "2.0.0",
  "description": "One-click import from ContactOut search results into Recruit Pro. Also works on LinkedIn profiles.",

  "permissions": ["storage", "tabs"],

  "host_permissions": [
    "https://contactout.com/*",
    "https://www.contactout.com/*",
    "https://app.contactout.com/*",
    "https://www.linkedin.com/*",
    "https://*.up.railway.app/*",
    "https://*.railway.app/*",
    "http://localhost:*/*"
  ],

  "content_scripts": [
    {
      "matches": [
        "https://contactout.com/*",
        "https://www.contactout.com/*",
        "https://app.contactout.com/*",
        "https://www.linkedin.com/in/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "options.html",
    "default_title": "Recruit Pro"
  }
}
